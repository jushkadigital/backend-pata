# =================================================================
# Production environment variables
# Copy to .env.prod and fill with real values
# =================================================================

# ---- PostgreSQL ----
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---- Keycloak ----
KEYCLOAK_ADMIN_CLIENT_ID=quarkus-admin-client
KEYCLOAK_ADMIN_CLIENT_SECRET=

# ---- RabbitMQ ----
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# ---- Vault ----
VAULT_URL=http://vault:8200
VAULT_USERNAME=
VAULT_PASSWORD=

# ---- OpenTelemetry (optional, defaults to http://otel-collector:4317) ----
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317
